# ==========================================
# Operating System Files
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ==========================================
# Editor / IDE Files
# ==========================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains / IntelliJ
.idea/
*.iml

# Eclipse
.project
.cproject
.settings/

# ==========================================
# Build Artifacts & Output
# ==========================================
build/
**/build/
cmake-build-*/
*.bin
*.elf
*.map
*.hex
*.uf2
*.o
*.obj
*.a
*.lib
*.out
*.exe
flasher_args.json

# ==========================================
# ESP-IDF Specific
# ==========================================
# Local configuration (submit sdkconfig.defaults instead)
sdkconfig
sdkconfig.old
sdkconfig.ci
# Keep sdkconfig.defaults and other variants
!sdkconfig.defaults*

# Managed Components (ESP-IDF Component Manager)
# Dependencies are usually not committed, lock file is.
managed_components/
dependencies.lock

# ESP-IDF Tools (if local)
.espressif/
tools/esp-idf/

# ==========================================
# Python (Tools & Scripts)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
venv/
.venv/
env/
.env

# ==========================================
# C/C++ & Language Servers
# ==========================================
.clangd/
.ccls-cache/
compile_commands.json
*.gch

# ==========================================
# CMake
# ==========================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
Makefile

# ==========================================
# Documentation
# ==========================================
docs/_build/
doxygen/output/

# ==========================================
# Temporary / Backup Files
# ==========================================
*.bak
*.swp
*.swo
*.tmp
*.log


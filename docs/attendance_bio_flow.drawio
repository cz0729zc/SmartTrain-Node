        <mxCell id="e6" value="是" style="endArrow=block;html=1;" edge="1" parent="1" source="found" target="bound"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="否" style="endArrow=block;html=1;" edge="1" parent="1" source="bound" target="enroll"><mxGeometry relative="1" as="geometry"/></mxCell>

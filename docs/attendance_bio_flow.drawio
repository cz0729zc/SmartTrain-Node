<mxfile host="app.diagrams.net" modified="2026-04-21T00:00:00.000Z" agent="GPT-5.3-Codex" version="24.7.17" editor="draw.io">
  <diagram id="attendance-bio-flow" name="Attendance Bio Flow (Either-Or)">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="start" value="开始\nRFID 卡片进入回调" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="ready" value="人脸/指纹模块\n是否就绪?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="290" y="295" width="190" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="skip" value="显示失败页\n2 秒倒计时后返回首页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="530" y="200" width="220" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="find" value="读卡学号 + UID\n查档案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="320" width="220" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="found" value="档案命中?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="790" y="320" width="170" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="unreg" value="未注册卡片\n失败页 + 倒计时返回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1000" y="430" width="220" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="bound" value="人脸和指纹\n都已绑定?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1000" y="300" width="190" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="enroll" value="首次注册流程\n绑定人脸 ID + 指纹页号" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1240" y="220" width="230" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="select" value="显示二选一页面\n用户选择: 人脸 / 指纹" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1240" y="370" width="230" height="105" as="geometry"/>
        </mxCell>

        <mxCell id="which" value="选择了哪种方式?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1520" y="380" width="190" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="faceOnly" value="仅做人脸验证\nuser_id 匹配即成功" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1760" y="300" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="fingerOnly" value="仅做指纹验证\npage_id 匹配即成功" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1760" y="450" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ok" value="成功页\n显示 2 秒倒计时\n自动返回首页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="2020" y="300" width="180" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="fail" value="失败页\n显示 2 秒倒计时\n自动返回首页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="2020" y="450" width="180" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="end" value="结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
